{
  "name": "felic-chat",
  "version": "0.1.0",
  "private": true,
  "main": "public/electron.js",
  "homepage": "./",
  "build": {
    "appId": "com.felicchat.app",
    "productName": "Felic Chat",
    "files": [
      "build/**/*",
      "node_modules/**/*"
    ],
    "directories": {
      "buildResources": "public"
    },
    "win": {
      "icon": "public/chat-logo.ico"
    },
    "extraMetadata": {
      "main": "build/electron.js"
    }
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "cra-template": "1.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-scripts": "5.0.1",
    "socket.io-client": "^4.8.3",
    "web-vitals": "^5.1.0"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "eject": "react-scripts eject",
    "electron-start": "concurrently \"set BROWSER=none && npm start\" \"wait-on http://localhost:3000 && cross-env ELECTRON_RUN_AS_NODE= electron .\"",
    "electron-pack": "npx @electron/packager . \"Felic Chat\" --platform=win32 --arch=x64 --out=dist --overwrite --icon=public/chat-logo.ico",
    "electron-dist": "npm run build && npx @electron/packager . \"Felic Chat\" --platform=win32 --arch=x64 --out=dist --overwrite --ignore=\"^/node_modules\" --icon=public/chat-logo.ico"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "wait-on": "^9.0.4"
  }
}
